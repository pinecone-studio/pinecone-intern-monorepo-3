{
  "extends": ["plugin:@nx/react-typescript", "next", "next/core-web-vitals", "../../../../.eslintrc.json"],
  "ignorePatterns": ["!**/*", ".next/**/*", "src/generated/**/*", "dist/**/*", "build/**/*"],
  "overrides": [
    {
      "files": ["*.*"],
      "rules": {
        "@next/next/no-html-link-for-pages": "off"
      }
    },
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@next/next/no-html-link-for-pages": ["error", "apps/2j/concert-ticket/backend/pages"]
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "complexity": ["warn", 8],
        "max-lines": ["warn", 200],
        "@typescript-eslint/no-explicit-any": "warn",
        "unicorn/filename-case": "off",
        "prefer-const": "warn"
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "rules": {}
    },
    {
      "files": ["*.spec.ts", "*.spec.tsx", "*.spec.js", "*.spec.jsx"],
      "env": {
        "jest": true
      }
    }
  ]
}
